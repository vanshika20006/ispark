# Backend API environment variables
# Copy these to api/.env or set them in your environment
PORT=8080
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=user
DB_NAME=isparc
DB_SSLMODE=disable

JWT_SECRET=super_secret_jwt_access_token_key_12345
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_67890

# SMTP config for OTP (configured for Brevo SMTP relay)
SMTP_HOST=smtp-relay.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SENDER=your_email@example.com
