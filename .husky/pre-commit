#!/usr/bin/env sh
set -eu

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

# Frontend: run lint-staged inside web/ so Prettier/ESLint resolve their plugins
# from web/node_modules and only touch staged web files.
if echo "$staged_files" | grep -q '^web/'; then
	if [ ! -d web/node_modules ]; then
		echo "web/node_modules is missing. Run 'cd web && npm install' before committing web changes."
		exit 1
	fi

	(cd web && npx --no-install lint-staged)
fi

# Backend: gofmt staged Go files, then re-stage what changed.
gofiles="$(echo "$staged_files" | grep '\.go$' || true)"
if [ -n "$gofiles" ]; then
	echo "$gofiles" | while IFS= read -r file; do
		gofmt -w "$file"
		git add "$file"
	done
fi
